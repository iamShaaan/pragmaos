rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper functions ────────────────────────────────────────────────────
    function isAuthed() {
      return request.auth != null;
    }

    function isOwner(resource) {
      return isAuthed()
        && resource != null
        && resource.data.owner_id == request.auth.uid;
    }

    function isOrphan(resource) {
      return isAuthed()
        && resource != null
        && (!('owner_id' in resource.data) || resource.data.owner_id == null);
    }

    // =========================================================================
    // TASK MASTER  (apps/task-master-v1/...)
    // =========================================================================

    // ── User Profiles ─────────────────────────────────────────────────────────
    // Any authenticated user can read profiles — needed for user-code/email search
    // during invitation flows. Write restricted to own profile only.
    match /apps/task-master-v1/users/{userId} {
      allow read:  if isAuthed();
      allow write: if isAuthed() && request.auth.uid == userId;
    }

    // ── Invitations ───────────────────────────────────────────────────────────
    // Must be signed in to read an invitation token (accepting requires auth anyway).
    match /apps/task-master-v1/invitations/{token} {
      allow read:           if isAuthed();
      allow create, update: if isAuthed();
    }

    // ── Tasks ─────────────────────────────────────────────────────────────────
    // Three read paths: owner, direct assignee, project member (shared tasks).
    // Matches the three listenCollection calls in App.tsx DataLoader.
    match /apps/task-master-v1/tasks/{docId} {
      allow create: if isAuthed();
      allow read:   if isAuthed() && (
                      resource.data.owner_id == request.auth.uid
                      || resource.data.assignee_id == request.auth.uid
                      || request.auth.uid in resource.data.project_member_uids
                    );
      allow update, delete: if isOwner(resource) || isOrphan(resource);
    }

    // ── Projects ──────────────────────────────────────────────────────────────
    // Owner or any member can read. Admins can update/delete.
    match /apps/task-master-v1/projects/{docId} {
      allow create: if isAuthed();
      allow read:   if isAuthed() && (
                      resource.data.owner_id == request.auth.uid
                      || request.auth.uid in resource.data.member_uids
                    );
      allow update: if isOwner(resource)
                    || isOrphan(resource)
                    || (isAuthed() && resource != null && resource.data.admin_uids is list
                        && request.auth.uid in resource.data.admin_uids);
      allow delete: if isOwner(resource)
                    || isOrphan(resource)
                    || (isAuthed() && resource != null && resource.data.admin_uids is list
                        && request.auth.uid in resource.data.admin_uids);
    }

    // ── All other task-master-v1 collections ──────────────────────────────────
    // (meetings, notes, clients, routines, daily_logs, finance_entries,
    //  savings, emis, invoices, files, actions)
    // Owner-only read/write. Queries in App.tsx already filter by owner_id.
    match /apps/task-master-v1/{collection}/{docId} {
      allow create:         if isAuthed();
      allow read:           if isOwner(resource);
      allow update, delete: if isOwner(resource) || isOrphan(resource);
    }

    // ── Collection-level list queries ─────────────────────────────────────────
    // Security is enforced by the per-document rules above and by the query
    // constraints in the app (all queries include owner_id/member_uids where clauses).
    match /apps/task-master-v1/{collection} {
      allow list: if isAuthed();
    }

    match /apps/task-master-v1/users {
      allow list: if isAuthed();
    }

    // =========================================================================
    // OTHER APPS (Profluencer, CRM-Tool, etc.)
    // =========================================================================
    match /apps/{appId}/users/{userId} {
      allow read:  if isAuthed();
      allow write: if isAuthed() && request.auth.uid == userId;
    }

    match /apps/{appId}/{collection}/{docId} {
      allow create:         if isAuthed();
      allow read:           if isOwner(resource);
      allow update, delete: if isAuthed()
                            && (resource == null
                                || !('owner_id' in resource.data)
                                || resource.data.owner_id == null
                                || resource.data.owner_id == request.auth.uid);
    }

    match /apps/{appId}/{collection} {
      allow list: if isAuthed();
    }

  }
}
